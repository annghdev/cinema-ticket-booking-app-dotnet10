@using CinemaTicketBooking.Application
@using CinemaTicketBooking.Application.Features
@using CinemaTicketBooking.Application.Abstractions
@using CinemaTicketBooking.Application.Common.Auth
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model PagedResult<ConcessionDto>

@{
    Layout = "_Layout";
    var canManage = (await AuthorizationService.AuthorizeAsync(User, Permissions.ConcessionsManage)).Succeeded;
}





    <div class="overflow-hidden rounded-2xl border border-white/5 bg-surface-container-low/40 backdrop-blur-md shadow-2xl animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="px-8 py-6 flex flex-col xl:flex-row xl:items-center justify-between gap-6 border-b border-white/5 bg-white/[0.01]">
            <h4 class="font-headline font-bold text-xl text-on-surface flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-secondary shadow-[0_0_8px_#00f4fe]"></span>
                Danh sách bắp nước
            </h4>
            
            <div class="flex flex-col md:flex-row items-center gap-4 w-full xl:w-auto">
                @if (canManage)
                {
                    <button onclick="openAddConcessionModal()" class="w-full md:w-auto h-10 py-2.5 px-6 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary text-xs font-bold shadow-[0_4px_15px_rgba(97,180,254,0.3)] hover:shadow-[0_4px_25px_rgba(97,180,254,0.5)] active:scale-95 transition-all flex items-center justify-center gap-2 whitespace-nowrap">
                        <span class="material-symbols-outlined text-lg">add</span>
                        <span>Thêm sản phẩm</span>
                    </button>
                }
                
                <form method="get" class="flex flex-col md:flex-row items-center gap-3 w-full md:w-auto">
                    <!-- Status Dropdown -->
                    <div class="w-full md:w-40">
                        <select name="isAvailable" onchange="this.form.submit()" class="w-full bg-surface-container-high border-none text-xs rounded-xl text-slate-300 focus:ring-1 focus:ring-primary py-2.5 px-4 h-10 transition-all cursor-pointer">
                            <option value="">Tất cả trạng thái</option>
                            <option value="true" selected="@(Context.Request.Query["isAvailable"] == "true")">Đang bán</option>
                            <option value="false" selected="@(Context.Request.Query["isAvailable"] == "false")">Tạm ngưng</option>
                        </select>
                    </div>

                    <!-- Search Input with Icon -->
                    <div class="flex items-center bg-surface-container-high rounded-xl border border-white/5 focus-within:border-primary/50 focus-within:ring-1 focus-within:ring-primary transition-all h-10 w-full md:w-64">
                        <input type="text" name="searchTerm" id="searchInput" placeholder="Tìm tên sản phẩm..." class="flex-1 bg-transparent border-none text-xs text-slate-300 py-2.5 px-4 focus:ring-0" value="@Context.Request.Query["searchTerm"]" />
                        <div class="w-px h-4 bg-white/10"></div>
                        <button type="submit" id="searchBtn" class="px-3 h-full text-slate-400 hover:text-on-surface transition-colors flex items-center justify-center">
                            <span class="material-symbols-outlined text-sm" id="searchIcon">search</span>
                        </button>
                    </div>

                    <!-- Reset Button -->
                    <a asp-action="Index" class="w-10 h-10 aspect-square flex items-center justify-center rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 transition-all" title="Reset">
                        <span class="material-symbols-outlined text-base">restart_alt</span>
                    </a>
                </form>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[600px]">
                <thead class="bg-white/[0.02]">
                    <tr>
                        <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Sản phẩm</th>
                        <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5 text-right">Giá bán</th>
                        <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5 text-center">Trạng thái</th>
                        <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5 text-right">Thao tác</th>
                    </tr>
                </thead>
            <tbody class="divide-y divide-white/5">
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="4" class="px-8 py-10 text-center text-sm text-on-surface-variant">Không tìm thấy sản phẩm nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var c in Model.Items)
                    {
                        <tr class="hover:bg-white/[0.03] transition-colors group">
                            <td class="px-8 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-white/5 border border-white/10 shrink-0">
                                        <img src="@c.ImageUrl" alt="@c.Name" class="w-full h-full object-cover" onerror="this.src='/img/placeholder-concession.png'" />
                                    </div>
                                    <span class="font-headline font-bold text-on-surface">@c.Name</span>
                                </div>
                            </td>
                            <td class="px-8 py-4 text-right font-mono font-bold text-primary">
                                @c.Price.ToString("N0") <span class="text-[8px] opacity-50">₫</span>
                            </td>
                            <td class="px-8 py-4 text-center">
                                <button onclick="toggleConcessionStatus('@c.Id', @((!c.IsAvailable).ToString().ToLower()))" class="px-3 py-1 rounded-full @(c.IsAvailable ? "bg-secondary/10 text-secondary border-secondary/20" : "bg-white/5 text-slate-400 border-white/10") text-[10px] font-bold border uppercase hover:scale-105 transition-all">
                                    @(c.IsAvailable ? "Đang bán" : "Tạm ngưng")
                                </button>
                            </td>
                            <td class="px-8 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <button 
                                        data-id="@c.Id"
                                        data-name="@c.Name"
                                        data-price="@c.Price"
                                        data-image="@c.ImageUrl"
                                        onclick="openUpdateConcessionModal(this)" 
                                        class="w-10 h-10 aspect-square flex items-center justify-center rounded-xl bg-white/5 text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                    </button>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="px-8 py-4 bg-white/[0.01] flex items-center justify-between border-t border-white/5">
                <span class="text-[10px] font-medium text-on-surface-variant">Hiển thị <span class="text-on-surface">@Model.Items.Count() trên @Model.TotalItems</span> sản phẩm</span>
                <div class="flex gap-2">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" 
                           asp-route-pageNumber="@i" 
                           asp-route-searchTerm="@Context.Request.Query["searchTerm"]"
                           asp-route-isAvailable="@Context.Request.Query["isAvailable"]"
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-[10px] font-bold transition-all @(i == Model.PageNumber ? "bg-primary text-on-primary shadow-lg shadow-primary/20" : "bg-white/5 text-slate-400 hover:bg-white/10")">
                            @i
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal: Add/Update Concession -->
<div id="concessionModal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="glass-panel w-full max-w-4xl rounded-3xl border border-white/10 p-0 shadow-2xl bg-slate-900/90 relative overflow-hidden">
        <div class="p-6 border-b border-white/5 flex items-center justify-between">
            <h3 class="font-headline font-bold text-xl text-on-surface flex items-center gap-2">
                <span id="modalDot" class="w-3 h-3 rounded-full bg-primary shadow-[0_0_10px_#61b4fe]"></span>
                <span id="modalTitle">THÊM BẮP NƯỚC</span>
            </h3>
            <button onclick="closeConcessionModal()" class="text-slate-400 hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <form id="concessionForm" class="p-8">
            <input type="hidden" id="modalConcessionId" name="id" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Left Side: Basic Info -->
                <div class="space-y-4 text-sm">
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Tên sản phẩm</label>
                        <input type="text" name="name" id="modalName" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" placeholder="Ví dụ: Combo Bắp Lớn + 2 Coke" />
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Giá bán (VNĐ)</label>
                        <input type="number" name="price" id="modalPrice" required min="0" step="1000" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" placeholder="0" />
                    </div>

                    <div id="modalActiveField">
                        <label class="block text-xs font-semibold text-slate-400 mb-2">Trạng thái</label>
                        <label class="flex items-center gap-3 cursor-pointer group bg-white/5 p-3 rounded-xl border border-white/5 hover:border-primary/20 transition-all">
                            <div class="relative">
                                <input type="checkbox" name="isAvailable" id="modalIsAvailable" class="peer hidden" checked />
                                <div class="w-10 h-5 bg-white/10 rounded-full border border-white/10 peer-checked:bg-primary/20 peer-checked:border-primary/40 transition-all"></div>
                                <div class="absolute left-1 top-1 w-3 h-3 bg-slate-500 rounded-full transition-all peer-checked:left-6 peer-checked:bg-primary shadow-sm"></div>
                            </div>
                            <span class="text-xs font-semibold text-slate-400 group-hover:text-slate-200 transition-colors">Mở bán ngay khi tạo</span>
                        </label>
                    </div>
                </div>

                <!-- Right Side: Media -->
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Link ảnh (URL)</label>
                        <input type="url" name="imageUrl" id="modalImage" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" placeholder="https://..." />
                    </div>
                    
                    <div class="relative group">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2 ml-1">Upload ảnh</label>
                        <div id="concessionDropZone" class="relative border-2 border-dashed border-white/10 rounded-2xl p-8 text-center cursor-pointer hover:border-primary/40 hover:bg-primary/5 transition-all group overflow-hidden">
                            <input type="file" id="concessionFileInput" accept="image/jpeg,image/png,image/gif,image/webp,image/avif" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                            
                            <div id="concessionUploadPrompt">
                                <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 group-hover:bg-primary/10 transition-all duration-500">
                                    <span class="material-symbols-outlined text-3xl text-slate-500 group-hover:text-primary transition-colors">cloud_upload</span>
                                </div>
                                <p class="text-sm font-semibold text-slate-300">Kéo thả hoặc click để chọn ảnh</p>
                                <p class="text-xs text-slate-500 mt-1">Hỗ trợ JPG, PNG, WebP (Max 5MB)</p>
                            </div>

                            <div id="concessionPreview" class="hidden relative z-20">
                                <img id="concessionPreviewImg" class="max-h-48 mx-auto rounded-xl shadow-2xl border border-white/10" />
                                <div class="mt-4 flex items-center justify-center gap-3">
                                    <p id="concessionFileName" class="text-xs text-slate-400 truncate max-w-[150px]"></p>
                                    <button type="button" onclick="clearConcessionPreview()" class="p-1.5 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-all">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Upload Loading Overlay -->
                            <div id="concessionUploadLoading" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm hidden items-center justify-center z-30">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-8 h-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                                    <p class="text-[10px] font-bold text-primary tracking-widest uppercase">Đang tải lên...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-white/5 mt-8">
                <button type="button" id="btnDeleteConcession" onclick="confirmDeleteFromModal()" class="py-2.5 px-4 rounded-xl bg-red-500/10 text-red-400 hover:bg-red-500/20 text-xs font-bold transition-all hidden flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">delete</span>
                    Xóa sản phẩm
                </button>
                <div class="flex items-center gap-3 ml-auto">
                    <button type="button" onclick="closeConcessionModal()" class="py-2.5 px-6 rounded-xl bg-white/5 text-slate-300 hover:bg-white/10 text-xs font-bold transition-all">
                        Đóng
                    </button>
                    <button type="submit" class="py-2.5 px-8 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary text-xs font-bold shadow-[0_4px_15px_rgba(97,180,254,0.3)] hover:shadow-[0_4px_25px_rgba(97,180,254,0.5)] transition-all">
                        Lưu sản phẩm
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =============================================
        // Search Input Logic
        // =============================================
        const searchInput = document.getElementById('searchInput');
        const searchIcon = document.getElementById('searchIcon');
        const searchBtn = document.getElementById('searchBtn');

        function updateSearchIcon() {
            if (searchInput.value.trim() !== '') {
                searchIcon.textContent = 'close';
                searchIcon.classList.add('text-red-500');
                searchIcon.classList.remove('text-sm');
                searchIcon.classList.add('text-base', 'font-bold');
            } else {
                searchIcon.textContent = 'search';
                searchIcon.classList.remove('text-red-500', 'font-bold');
                searchIcon.classList.add('text-sm');
                searchIcon.classList.remove('text-base');
            }
        }

        if (searchInput) {
            searchInput.addEventListener('input', updateSearchIcon);
            updateSearchIcon();
        }

        if (searchBtn) {
            searchBtn.addEventListener('click', function(e) {
                if (searchIcon.textContent === 'close' && e.detail > 0) {
                    e.preventDefault();
                    searchInput.value = '';
                    
                    const url = new URL(window.location.href);
                    if (url.searchParams.has('searchTerm')) {
                        url.searchParams.delete('searchTerm');
                        url.searchParams.delete('pageNumber');
                        window.location.href = url.toString();
                    } else {
                        updateSearchIcon();
                        searchInput.focus();
                    }
                }
            });
        }

        const modal = document.getElementById('concessionModal');
        const form = document.getElementById('concessionForm');
        let isUpdate = false;
        let concessionFile = null;

        // =============================================
        // File upload preview helpers
        // =============================================

        function setupConcessionFilePreview() {
            const input = document.getElementById('concessionFileInput');
            input.addEventListener('change', async function () {
                const file = this.files[0];
                if (!file) return;

                // Show loading
                document.getElementById('concessionUploadLoading').classList.remove('hidden');
                document.getElementById('concessionUploadLoading').classList.add('flex');

                try {
                    const formData = new FormData();
                    formData.append('file', file);
                    const resp = await fetch('/Concession/UploadImage', { method: 'POST', body: formData });
                    const result = await resp.json();

                    if (result.success) {
                        // Auto-fill URL input
                        document.getElementById('modalImage').value = result.url;
                        
                        // Update Preview
                        document.getElementById('concessionPreviewImg').src = result.url;
                        document.getElementById('concessionFileName').textContent = file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
                        document.getElementById('concessionPreview').classList.remove('hidden');
                        document.getElementById('concessionUploadPrompt').classList.add('hidden');
                        
                        concessionFile = file;
                        showToast('Tải lên ảnh thành công!', 'success');
                    } else {
                        showToast(result.message, 'error');
                        input.value = '';
                    }
                } catch (err) {
                    console.error(err);
                    showToast('Lỗi khi tải lên ảnh.', 'error');
                    input.value = '';
                } finally {
                    document.getElementById('concessionUploadLoading').classList.add('hidden');
                    document.getElementById('concessionUploadLoading').classList.remove('flex');
                }
            });
        }
        setupConcessionFilePreview();

        function clearConcessionPreview() {
            concessionFile = null;
            document.getElementById('concessionFileInput').value = '';
            document.getElementById('modalImage').value = '';
            document.getElementById('concessionPreview').classList.add('hidden');
            document.getElementById('concessionUploadPrompt').classList.remove('hidden');
        }

        // =============================================
        // Modal functions
        // =============================================

        function openAddConcessionModal() {
            isUpdate = false;
            document.getElementById('modalTitle').innerText = 'THÊM BẮP NƯỚC';
            document.getElementById('modalConcessionId').value = '';
            document.getElementById('modalActiveField').style.display = 'block';
            document.getElementById('btnDeleteConcession').classList.add('hidden');
            form.reset();
            clearConcessionPreview();
            modal.classList.remove('hidden');
        }

        function openUpdateConcessionModal(btn) {
            isUpdate = true;
            document.getElementById('modalTitle').innerText = 'CẬP NHẬT BẮP NƯỚC';
            document.getElementById('modalActiveField').style.display = 'none';
            document.getElementById('btnDeleteConcession').classList.remove('hidden');
            
            document.getElementById('modalConcessionId').value = btn.dataset.id;
            document.getElementById('modalName').value = btn.dataset.name;
            document.getElementById('modalPrice').value = btn.dataset.price;
            document.getElementById('modalImage').value = btn.dataset.image;
            
            clearConcessionPreview();
            modal.classList.remove('hidden');
        }

        function confirmDeleteFromModal() {
            const id = document.getElementById('modalConcessionId').value;
            const name = document.getElementById('modalName').value;
            confirmDeleteConcession(id, name);
        }

        function closeConcessionModal() {
            modal.classList.add('hidden');
        }

        // =============================================
        // Form submission
        // =============================================

        form.onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // Format data
            data.price = parseFloat(data.price);
            if (!isUpdate) {
                data.isAvailable = document.getElementById('modalIsAvailable').checked;
            }

            const url = isUpdate ? '/Concession/Update' : '/Concession/Create';
            
            try {
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await resp.json();
                
                if (result.success) {
                    showToast(result.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(result.message, 'error');
                }
            } catch (err) {
                showToast('Đã có lỗi xảy ra!', 'error');
            }
        };

        // =============================================
        // Status toggle & Delete
        // =============================================

        async function toggleConcessionStatus(id, isAvailable) {
            try {
                const resp = await fetch('/Concession/ToggleStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, isAvailable })
                });
                const result = await resp.json();
                if (result.success) {
                    showToast(result.message, 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(result.message, 'error');
                }
            } catch (err) {
                showToast('Không thể cập nhật trạng thái!', 'error');
            }
        }

        async function confirmDeleteConcession(id, name) {
            if (confirm(`Bạn có chắc muốn xóa sản phẩm "${name}"? Hành động này không thể hoàn tác.`)) {
                try {
                    const resp = await fetch(`/Concession/Delete?id=${id}`, { method: 'POST' });
                    const result = await resp.json();
                    if (result.success) {
                        showToast(result.message, 'success');
                        setTimeout(() => location.reload(), 800);
                    } else {
                        showToast(result.message, 'error');
                    }
                } catch (err) {
                    showToast('Lỗi khi xóa sản phẩm!', 'error');
                }
            }
        }
    </script>
}
