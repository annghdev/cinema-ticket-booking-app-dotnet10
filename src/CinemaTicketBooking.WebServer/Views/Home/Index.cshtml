@using CinemaTicketBooking.WebServer.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<!-- Summary Cards (KPIs) -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 aspect-square flex items-center justify-center rounded-xl bg-primary/10 text-primary">
                <span class="material-symbols-outlined" data-icon="payments">payments</span>
            </div>
            <span class="@(Model.Summary.RevenueTrendPercentage >= 0 ? "text-secondary" : "text-error") text-xs font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]" data-icon="@(Model.Summary.RevenueTrendPercentage >= 0 ? "trending_up" : "trending_down")">@(Model.Summary.RevenueTrendPercentage >= 0 ? "trending_up" : "trending_down")</span>
                @(Model.Summary.RevenueTrendPercentage >= 0 ? "+" : "")@Model.Summary.RevenueTrendPercentage.ToString("F1")%
            </span>
        </div>
        <p class="text-on-surface-variant text-sm font-label uppercase tracking-widest mb-1">Doanh thu hàng ngày</p>
        <h3 class="text-3xl font-headline font-bold">@Model.Summary.DailyRevenue.ToString("N0")₫</h3>
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    </div>
    <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 aspect-square flex items-center justify-center rounded-xl bg-secondary/10 text-secondary">
                <span class="material-symbols-outlined" data-icon="local_activity">local_activity</span>
            </div>
            <span class="@(Model.Summary.TicketTrendPercentage >= 0 ? "text-secondary" : "text-error") text-xs font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]" data-icon="@(Model.Summary.TicketTrendPercentage >= 0 ? "trending_up" : "trending_down")">@(Model.Summary.TicketTrendPercentage >= 0 ? "trending_up" : "trending_down")</span>
                @(Model.Summary.TicketTrendPercentage >= 0 ? "+" : "")@Model.Summary.TicketTrendPercentage.ToString("F1")%
            </span>
        </div>
        <p class="text-on-surface-variant text-sm font-label uppercase tracking-widest mb-1">Vé đã bán</p>
        <h3 class="text-3xl font-headline font-bold">@Model.Summary.DailyTicketsSold.ToString("N0")</h3>
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-secondary/30 to-transparent"></div>
    </div>
    <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 aspect-square flex items-center justify-center rounded-xl bg-tertiary/10 text-tertiary">
                <span class="material-symbols-outlined" data-icon="lunch_dining">lunch_dining</span>
            </div>
            <span class="@(Model.Summary.ConcessionTrendPercentage >= 0 ? "text-secondary" : "text-error") text-xs font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]"
                    data-icon="@(Model.Summary.ConcessionTrendPercentage >= 0 ? "trending_up" : "trending_down")">@(Model.Summary.ConcessionTrendPercentage >= 0 ? "trending_up" : "trending_down")</span>
                @(Model.Summary.ConcessionTrendPercentage >= 0 ? "+" : "")@Model.Summary.ConcessionTrendPercentage.ToString("F1")%
            </span>
        </div>
        <p class="text-on-surface-variant text-sm font-label uppercase tracking-widest mb-1">Doanh thu bắp nước</p>
        <h3 class="text-3xl font-headline font-bold">@Model.Summary.ConcessionRevenue.ToString("N0")₫</h3>
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-tertiary/30 to-transparent"></div>
    </div>
    <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 aspect-square flex items-center justify-center rounded-xl bg-surface-tint/10 text-surface-tint">
                <span class="material-symbols-outlined" data-icon="theaters">theaters</span>
            </div>
            <span class="text-on-surface-variant text-xs font-bold">Live</span>
        </div>
        <p class="text-on-surface-variant text-sm font-label uppercase tracking-widest mb-1">Phim đang chiếu</p>
        <h3 class="text-3xl font-headline font-bold">@Model.Summary.NowShowingMoviesCount</h3>
        <div
            class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-surface-tint/30 to-transparent">
        </div>
    </div>
</div>
<div class="grid grid-cols-1 xl:grid-cols-3 gap-8 mb-8">
    <!-- Revenue Analytics Section -->
    <div class="xl:col-span-2 glass-card rounded-2xl p-8 relative">
        <div class="flex justify-between items-center mb-8 flex-wrap gap-4">
            <div>
                <h4 class="text-xl font-headline font-bold text-on-surface">Phân tích doanh thu</h4>
                <p class="text-sm text-on-surface-variant">Hiệu suất tài chính theo thời gian</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex rounded-xl bg-surface-container-low p-1 border border-outline-variant/10 h-10">
                    <button id="btnWeekly" onclick="updateChartPeriod('weekly')"
                        class="px-5 py-1.5 text-[10px] font-bold rounded-lg text-on-surface-variant hover:text-on-surface transition-all">TUẦN</button>
                    <button id="btnMonthly" onclick="updateChartPeriod('monthly')"
                        class="px-5 py-1.5 text-[10px] font-bold rounded-lg bg-secondary text-on-secondary transition-all">THÁNG</button>
                    <button id="btnYearly" onclick="updateChartPeriod('yearly')"
                        class="px-5 py-1.5 text-[10px] font-bold rounded-lg text-on-surface-variant hover:text-on-surface transition-all">NĂM</button>
                </div>
                <div class="flex rounded-xl bg-surface-container-low p-1 border border-outline-variant/10 h-10">
                    <button id="btnBar" onclick="updateChartType('bar')"
                        class="px-3 rounded-lg bg-surface-container-high text-secondary border border-secondary/20 shadow-[0_0_10px_rgba(0,244,254,0.2)] flex items-center justify-center">
                        <span class="material-symbols-outlined text-base">bar_chart</span>
                    </button>
                    <button id="btnLine" onclick="updateChartType('line')"
                        class="px-3 rounded-lg text-on-surface-variant hover:text-on-surface transition-all flex items-center justify-center">
                        <span class="material-symbols-outlined text-base">show_chart</span>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="h-64 w-full">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>
    <!-- Revenue by Cinema Cluster -->
    <div class="glass-card rounded-2xl p-6">
        <div class="flex justify-between items-center mb-6">
            <h4 class="text-lg font-headline font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary" data-icon="hub">hub</span>
                Doanh thu cụm rạp
            </h4>
            <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest bg-surface-container px-2 py-1 rounded">Tháng này</span>
        </div>
        
        <div class="space-y-5">
            @foreach (var cinema in Model.CinemaRevenues)
            {
                <div class="group cursor-pointer">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-sm font-medium group-hover:text-secondary transition-colors">@cinema.CinemaName</span>
                        <span class="text-sm font-bold text-secondary font-headline">@cinema.Revenue.ToString("N0")₫</span>
                    </div>
                    <div class="w-full bg-surface-container rounded-full h-1.5 overflow-hidden border border-outline-variant/10">
                        <div class="bg-gradient-to-r from-secondary to-primary h-full rounded-full transition-all duration-1000 ease-out" style="width: @(cinema.Percentage)%"></div>
                    </div>
                </div>
            }
        </div>

        <button
            class="w-full mt-8 py-3 text-[10px] font-bold text-on-surface-variant hover:text-secondary hover:bg-secondary/5 rounded-xl border border-outline-variant/20 hover:border-secondary/30 transition-all uppercase tracking-[0.2em]">
            Báo cáo chi tiết rạp
        </button>
    </div>
</div>
<!-- Top Performing Movies -->
<div class="glass-card rounded-2xl overflow-hidden">
    <div class="p-8 border-b border-outline-variant/20 flex justify-between items-center">
        <h4 class="text-xl font-headline font-bold text-on-surface">Phim doanh thu hàng đầu</h4>
        <button class="text-secondary text-sm font-bold flex items-center gap-2 hover:underline">
            XEM CHI TIẾT
            <span class="material-symbols-outlined text-sm" data-icon="arrow_forward">arrow_forward</span>
        </button>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead
                class="bg-surface-container-lowest text-on-surface-variant text-[10px] uppercase tracking-widest font-label">
                <tr>
                    <th class="px-8 py-4">Phim</th>
                    <th class="px-8 py-4">Ngày phát hành</th>
                    <th class="px-8 py-4">Doanh thu</th>
                    <th class="px-8 py-4">Mục tiêu</th>
                    <th class="px-8 py-4">Xu hướng</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/10">
                @foreach (var movie in Model.TopMovies)
                {
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="px-8 py-4">
                            <div class="flex items-center gap-4">
                                <img class="w-12 h-16 rounded-lg object-cover"
                                     src="@movie.ThumbnailUrl" alt="@movie.Title" />
                                <div>
                                    <p class="font-bold">@movie.Title</p>
                                    <p class="text-xs text-on-surface-variant">@movie.Genre</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-4 text-sm text-on-surface-variant">@movie.ReleaseDate.ToString("MMM dd, yyyy")</td>
                        <td class="px-8 py-4 font-headline font-bold">@movie.BoxOffice.ToString("N0")₫</td>
                        <td class="px-8 py-4">
                            <div class="w-32">
                                <div class="flex justify-between text-[10px] mb-1">
                                    <span>@movie.ProgressPercentage.ToString("F0")%</span>
                                    <span>@((movie.TargetGoal / 1000000).ToString("N0"))m</span>
                                </div>
                                <div class="w-full bg-surface-container rounded-full h-1.5">
                                    <div class="bg-secondary h-1.5 rounded-full neon-glow" style="width: @(movie.ProgressPercentage)%"></div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let revenueChart;
        let currentType = 'bar';
        let currentPeriod = 'monthly';

        const chartData = {
            weekly: @Html.Raw(Json.Serialize(Model.WeeklyRevenueChart)),
            monthly: @Html.Raw(Json.Serialize(Model.MonthlyRevenueChart)),
            yearly: @Html.Raw(Json.Serialize(Model.YearlyRevenueChart))
        };

        function initChart() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            const data = chartData[currentPeriod];
            
            revenueChart = new Chart(ctx, {
                type: currentType,
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Doanh thu (₫)',
                        data: data.data,
                        backgroundColor: currentType === 'bar' ? 'rgba(0, 244, 254, 0.3)' : 'rgba(97, 180, 254, 0.2)',
                        borderColor: currentType === 'bar' ? '#00f4fe' : '#61b4fe',
                        borderWidth: 2,
                        borderRadius: currentType === 'bar' ? 6 : 0,
                        fill: currentType === 'line',
                        tension: 0.4,
                        pointBackgroundColor: '#00f4fe',
                        pointBorderColor: '#0b0e14',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { 
                                color: '#a9abb3',
                                callback: value => (value >= 1000000 ? (value / 1000000).toFixed(1) + 'M' : value.toLocaleString()) + '₫'
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#a9abb3' }
                        }
                    }
                }
            });
        }

        window.updateChartPeriod = function(period) {
            currentPeriod = period;
            
            // UI Toggle
            const periods = ['weekly', 'monthly', 'yearly'];
            periods.forEach(p => {
                const btn = document.getElementById('btn' + p.charAt(0).toUpperCase() + p.slice(1));
                if (btn) {
                    btn.className = period === p 
                        ? 'px-4 py-1.5 text-[10px] font-bold rounded-md bg-secondary text-on-secondary transition-all'
                        : 'px-4 py-1.5 text-[10px] font-bold rounded-md text-on-surface-variant hover:text-on-surface transition-all';
                }
            });

            const newData = chartData[period];
            revenueChart.data.labels = newData.labels;
            revenueChart.data.datasets[0].data = newData.data;
            revenueChart.update();
        };

        window.updateChartType = function(type) {
            currentType = type;
            
            // UI Toggle
            document.getElementById('btnBar').className = type === 'bar'
                ? 'p-1.5 rounded-md bg-surface-container-high text-secondary border border-secondary/20 shadow-[0_0_10px_rgba(0,244,254,0.2)]'
                : 'p-1.5 rounded-md text-on-surface-variant hover:text-on-surface transition-all';
                
            document.getElementById('btnLine').className = type === 'line'
                ? 'p-1.5 rounded-md bg-surface-container-high text-secondary border border-secondary/20 shadow-[0_0_10px_rgba(0,244,254,0.2)]'
                : 'p-1.5 rounded-md text-on-surface-variant hover:text-on-surface transition-all';

            revenueChart.destroy();
            initChart();
        };

        document.addEventListener('DOMContentLoaded', initChart);
    </script>
}
