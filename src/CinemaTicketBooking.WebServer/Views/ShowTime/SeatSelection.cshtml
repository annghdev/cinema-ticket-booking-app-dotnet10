@model CinemaTicketBooking.Application.Features.ShowTimeDetailDto
@{
    ViewData["Title"] = $"Sơ đồ ghế: {Model.MovieName}";
}

<div class="space-y-6">
    <!-- Header Info -->
    <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-white/[0.01] flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold font-headline text-on-surface">@Model.MovieName</h1>
            <p class="text-xs text-on-surface-variant mt-1 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-secondary shadow-[0_0_8px_#00f4fe]"></span>
                @Model.CinemaName • @Model.ScreenCode • @Model.StartAt.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
        <div class="flex items-center gap-4">
            <a href="/ShowTime?date=@ViewData["ReturnDate"]" class="py-2.5 px-4 rounded-xl bg-white/5 text-slate-300 hover:bg-white/10 text-xs font-bold border border-white/5 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Quay lại lịch chiếu
            </a>
        </div>
    </div>

    <!-- Seat map visualization -->
    <div class="glass-panel p-8 rounded-2xl border border-white/5 bg-white/[0.01] flex flex-col items-center">
        <div class="flex flex-col items-center w-fit mx-auto">
            <!-- Screen arc -->
            <div class="relative flex h-12 w-full shrink-0 items-center justify-center overflow-hidden rounded-t-[50%] border-t-4 border-secondary bg-gradient-to-t from-transparent to-secondary/10 shadow-[0_-15px_30px_rgba(0,244,254,0.2)] mb-12">
                <span class="mt-2 font-headline text-xs uppercase tracking-[0.3em] text-secondary">Màn hình chiếu</span>
            </div>

            <!-- Dynamic seating structure -->
            <div id="seatMapContainer" class="overflow-x-auto flex justify-center py-4">
                <div id="seatGrid" class="grid gap-2 p-4"></div>
            </div>
        </div>

        <!-- Legend mapping -->
        <div class="mt-8 flex flex-wrap justify-center gap-4 text-xs text-on-surface-variant">
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-white/10 bg-slate-800"></span>
                <span>Khả dụng (Thường)</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-amber-300/40 bg-amber-500/10"></span>
                <span>Khả dụng (VIP)</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-fuchsia-300/40 bg-fuchsia-500/10"></span>
                <span>Khả dụng (SweetBox)</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-slate-500/40 bg-slate-700/50 animate-pulse"></span>
                <span>Đang chọn</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-yellow-500/30 bg-yellow-500/40 animate-pulse"></span>
                <span>Đang thanh toán</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded border border-red-500/20 bg-red-500/30 text-red-400"></span>
                <span>Đã đặt</span>
            </div>
        </div>
    </div>

    <!-- Booking Trail Logs -->
    <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-white/[0.01]">
        <h3 class="text-lg font-headline font-bold text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-[#00f4fe]">history</span>
            Lịch sử đặt vé
        </h3>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/5 text-[11px] uppercase tracking-wider text-on-surface-variant">
                        <th class="py-3 px-4">Mã Đặt Vé</th>
                        <th class="py-3 px-4">Khách Hàng</th>
                        <th class="py-3 px-4">Số Điện Thoại</th>
                        <th class="py-3 px-4">Email</th>
                        <th class="py-3 px-4">Ghế</th>
                        <th class="py-3 px-4">Tổng Tiền</th>
                        <th class="py-3 px-4">Trạng Thái</th>
                        <th class="py-3 px-4">Ngày Tạo</th>
                    </tr>
                </thead>
                <tbody id="bookingHistoryBody" class="divide-y divide-white/5 text-sm">
                    <tr>
                        <td colspan="8" class="text-center py-6 text-slate-500">Đang tải dữ liệu...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const showtimeId = '@Model.Id';
        let showtimeData = null;
        let ticketsMap = {};

        function parseSeatMap(seatMap) {
            if (!seatMap.trim()) return [];
            const trimmed = seatMap.trim();
            if (trimmed.startsWith("[")) {
                return JSON.parse(trimmed);
            }
            const rows = trimmed.split(/\r?\n/).map(l => l.trim()).filter(Boolean).map(l => l.split(/[,\s]+/).map(Number));
            return rows;
        }

        function generateSeatsFromSeatMap(seatGrid) {
            const seats = [];
            let sweetBoxCounter = 1;
            for (let row = 0; row < seatGrid.length; row++) {
                let seatNumber = 1;
                for (let col = seatGrid[row].length - 1; col >= 0; col--) {
                    const seatType = seatGrid[row][col];
                    if (seatType === 0 || seatType === 4) continue;
                    const code = seatType === 3 ? `Sweet${sweetBoxCounter++}` : `${String.fromCharCode(65 + row)}${seatNumber}`;
                    seats.push({ code, row: row + 1, column: col + 1, type: seatType });
                    seatNumber++;
                }
            }
            return seats;
        }

        async function loadSeatSelectionData() {
            if (window.showLoading) window.showLoading();
            try {
                const response = await fetch('/ShowTime/GetSeatSelectionData/' + showtimeId);
                const result = await response.json();
                
                if (result.success) {
                    showtimeData = result.showtime;
                    ticketsMap = {};
                    
                    // Index by seat code
                    showtimeData.tickets.forEach(t => {
                        const segments = t.code.split('-');
                        const seatCode = segments[segments.length - 1];
                        ticketsMap[seatCode] = t;
                    });

                    renderSeatGrid();
                    renderBookingHistory(result.bookingLogs);
                    initializeSignalR();
                } else {
                    window.showToast(result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                window.showToast('Không thể tải chi tiết trạng thái ghế.', 'error');
            } finally {
                if (window.hideLoading) window.hideLoading();
            }
        }

        function renderSeatGrid() {
            const gridContainer = document.getElementById('seatGrid');
            const seatGrid = parseSeatMap(showtimeData.seatMap);
            if (!seatGrid || seatGrid.length === 0) return;

            const cols = seatGrid[0].length;
            gridContainer.style.gridTemplateColumns = `repeat(${cols}, minmax(2.25rem, 2.75rem))`;
            gridContainer.innerHTML = '';

            const generatedSeats = generateSeatsFromSeatMap(seatGrid);
            const seatsByPosition = {};
            generatedSeats.forEach(s => {
                seatsByPosition[`${s.row}-${s.column}`] = s;
            });

            for (let rowIndex = 0; rowIndex < seatGrid.length; rowIndex++) {
                const row = seatGrid[rowIndex];

                for (let colIndex = 0; colIndex < row.length; colIndex++) {
                    const cell = row[colIndex];
                    
                    // Sweetbox wide cell selection mapping
                    if (cell === 4 && colIndex + 1 < row.length && row[colIndex + 1] === 3) {
                        const seat = seatsByPosition[`${rowIndex + 1}-${colIndex + 2}`];
                        renderSeatBtn(gridContainer, seat, rowIndex, colIndex, 2);
                        colIndex++;
                        continue;
                    }
                    if (cell === 3 && colIndex + 1 < row.length && row[colIndex + 1] === 4) {
                        const seat = seatsByPosition[`${rowIndex + 1}-${colIndex + 1}`];
                        renderSeatBtn(gridContainer, seat, rowIndex, colIndex, 2);
                        colIndex++;
                        continue;
                    }
                    
                    if (cell === 0) {
                        const empty = document.createElement('div');
                        empty.className = 'h-11 w-11';
                        gridContainer.appendChild(empty);
                        continue;
                    }
                    if (cell === 4) {
                        const empty = document.createElement('div');
                        empty.className = 'h-11 w-11';
                        gridContainer.appendChild(empty);
                        continue;
                    }

                    const seat = seatsByPosition[`${rowIndex + 1}-${colIndex + 1}`];
                    renderSeatBtn(gridContainer, seat, rowIndex, colIndex, 1);
                }
            }
        }

        function renderSeatBtn(container, seat, rowIndex, colIndex, span) {
            if (!seat) {
                const empty = document.createElement('div');
                empty.className = span === 2 ? 'h-11 col-span-2' : 'h-11 w-11';
                container.appendChild(empty);
                return;
            }

            const ticket = ticketsMap[seat.code];
            const status = ticket ? ticket.status : 0;

            const btn = document.createElement('div');
            btn.id = `seat-${seat.code}`;
            btn.title = `${seat.code}`;
            btn.innerText = seat.code;

            styleSeatButton(btn, status, seat.type, span);
            container.appendChild(btn);
        }

        function styleSeatButton(btn, status, type, span = 1) {
            const widthClass = span === 2 ? 'col-span-2 w-full' : 'w-11';
            btn.className = `relative h-11 ${widthClass} rounded-md border text-[11px] font-semibold flex items-center justify-center transition-all`;
            
            // 0=Available, 1=Locking, 2=PendingPayment, 3=Sold
            if (status === 3 || status === 'Sold' || status === 'Booked') {
                btn.classList.add('bg-red-500/30', 'border-red-500/20', 'text-red-400');
            } else if (status === 2 || status === 'PendingPayment') {
                btn.classList.add('bg-yellow-500/40', 'border-yellow-500/30', 'text-yellow-200', 'animate-pulse');
            } else if (status === 1 || status === 'Locking') {
                btn.classList.add('bg-slate-700/50', 'border-slate-500/40', 'text-slate-400', 'animate-pulse');
            } else {
                if (type === 1) {
                    btn.classList.add('bg-slate-800', 'border-white/10', 'text-slate-300');
                } else if (type === 2) {
                    btn.classList.add('bg-amber-500/10', 'border-amber-300/40', 'text-amber-200');
                } else {
                    btn.classList.add('bg-fuchsia-500/10', 'border-fuchsia-300/40', 'text-fuchsia-200');
                }
            }
        }

        function renderBookingHistory(logs) {
            const tbody = document.getElementById('bookingHistoryBody');
            if (!logs || logs.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center py-6 text-slate-500">Chưa có giao dịch đặt vé nào.</td></tr>`;
                return;
            }

            let html = '';
            const statusMap = {
                0: '<span class="px-2 py-1 rounded bg-slate-800 text-slate-400 text-xs font-semibold">Khởi tạo</span>',
                1: '<span class="px-2 py-1 rounded bg-yellow-500/20 text-yellow-400 text-xs font-semibold">Đang xử lý</span>',
                2: '<span class="px-2 py-1 rounded bg-[#00f4fe]/20 text-[#00f4fe] text-xs font-bold">Thành công</span>',
                3: '<span class="px-2 py-1 rounded bg-green-500/20 text-green-400 text-xs font-bold">Đã Checkin</span>',
                4: '<span class="px-2 py-1 rounded bg-red-500/20 text-red-400 text-xs font-semibold">Đã hủy</span>'
            };

            logs.forEach(l => {
                const date = new Date(l.createdAt);
                const dateStr = date.toLocaleString('vi-VN');
                const finalAmountStr = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(l.finalAmount);
                const statusHtml = statusMap[l.status] || `<span class="px-2 py-1 rounded bg-white/5 text-xs">${l.status}</span>`;

                html += `
                    <tr class="hover:bg-white/[0.01] transition-colors border-b border-white/5">
                        <td class="py-3 px-4 font-bold text-slate-300 text-xs">${l.bookingId.split('-')[0]}...</td>
                        <td class="py-3 px-4 text-slate-100 font-medium">${l.customerName}</td>
                        <td class="py-3 px-4 text-slate-400 text-xs">${l.phoneNumber || 'N/A'}</td>
                        <td class="py-3 px-4 text-slate-400 text-xs">${l.email || 'N/A'}</td>
                        <td class="py-3 px-4 text-secondary font-bold text-xs">${l.seatCodes.join(', ')}</td>
                        <td class="py-3 px-4 font-bold text-[#00f4fe]">${finalAmountStr}</td>
                        <td class="py-3 px-4">${statusHtml}</td>
                        <td class="py-3 px-4 text-slate-400 text-xs">${dateStr}</td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        let hubConnection = null;
        function initializeSignalR() {
            if (hubConnection) return;

            hubConnection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/tickets')
                .withAutomaticReconnect()
                .build();

            hubConnection.on('ticket-status-changed', function (event) {
                let seatCode = event.ticketCode;
                if (seatCode.includes('-')) {
                    const segs = seatCode.split('-');
                    seatCode = segs[segs.length - 1];
                }

                const ticket = ticketsMap[seatCode];
                if (ticket) {
                    ticket.status = event.status;
                }

                const btn = document.getElementById(`seat-${seatCode}`);
                if (btn) {
                    const seatGrid = parseSeatMap(showtimeData.seatMap);
                    
                    const row = Math.floor(seatCode.charCodeAt(0) - 65);
                    let span = 1;
                    if (seatCode.startsWith('Sweet')) {
                        span = 2; 
                    }

                    const generatedSeats = generateSeatsFromSeatMap(seatGrid);
                    const seatObj = generatedSeats.find(s => s.code === seatCode);
                    const type = seatObj ? seatObj.type : 1;

                    styleSeatButton(btn, event.status, type, span);
                }
            });

            hubConnection.start()
                .then(() => {
                    hubConnection.invoke('SubscribeShowTime', showtimeId)
                        .catch(err => console.error('SignalR Subscribe Error:', err));
                })
                .catch(err => console.error('SignalR Connection Error:', err));
        }

        document.addEventListener('DOMContentLoaded', loadSeatSelectionData);
    </script>
}
