@using CinemaTicketBooking.Application.Common.Auth
@model CinemaTicketBooking.WebServer.Controllers.RoleManagementViewModel

@{
    ViewData["Title"] = "Phân quyền truy cập";

    var permissionTranslations = new Dictionary<string, string>
    {
        { Permissions.BookingsViewAll, "Xem tất cả đơn đặt vé" },
        { Permissions.BookingsManage, "Bán vé & Kiểm tra đơn vé" },
        { Permissions.AccountsLock, "Khóa tài khoản nhân viên" },
        { Permissions.AccountsUnlock, "Mở khóa tài khoản nhân viên" },
        { Permissions.CinemasView, "Xem danh sách rạp" },
        { Permissions.CinemasManage, "Quản lý rạp chiếu" },
        { Permissions.ScreensView, "Xem phòng chiếu" },
        { Permissions.ScreensManage, "Quản lý phòng chiếu" },
        { Permissions.MoviesView, "Xem danh sách phim" },
        { Permissions.MoviesManage, "Quản lý kho phim" },
        { Permissions.ShowTimesView, "Xem lịch chiếu" },
        { Permissions.ShowTimesManage, "Quản lý lịch chiếu" },
        { Permissions.PricingPoliciesView, "Xem chính sách giá" },
        { Permissions.PricingPoliciesManage, "Quản lý chính sách giá" },
        { Permissions.SeatSelectionPoliciesView, "Xem chính sách ghế" },
        { Permissions.SeatSelectionPoliciesManage, "Quản lý chính sách ghế" },
        { Permissions.ConcessionsView, "Xem danh mục bắp nước" },
        { Permissions.ConcessionsManage, "Quản lý bắp nước" },
        { Permissions.CustomersView, "Xem danh sách khách hàng" },
        { Permissions.CustomersManage, "Quản lý hồ sơ khách hàng" },
        { Permissions.ReportsView, "Xem báo cáo doanh thu" },
        { Permissions.AnalysisView, "Xem phân tích chuyên sâu" }
    };
}


@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 bg-red-500/20 text-red-300 font-bold text-sm rounded-xl border border-red-500/30 shadow-[0_4px_15px_rgba(239,68,68,0.2)]">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="mb-6 p-4 bg-emerald-500/20 text-emerald-300 font-bold text-sm rounded-xl border border-emerald-500/30 shadow-[0_4px_15px_rgba(16,185,129,0.2)]">
        @TempData["Success"]
    </div>
}

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
    <!-- Left column: List of Roles -->
    <div class="xl:col-span-1 space-y-4">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Vai trò người dùng</h3>
        
        @foreach (var role in Model.Roles)
        {
            var isSysAdminRole = role.Name == RoleNames.SystemAdmin;
            var isAdminRole = role.Name == RoleNames.Admin;
            
            <button onclick="selectRole('@role.Id', '@role.Name', @isSysAdminRole.ToString().ToLower(), @isAdminRole.ToString().ToLower())" 
                    id="role-btn-@role.Id" 
                    class="role-card w-full text-left p-5 rounded-2xl border border-white/5 bg-slate-900/40 hover:bg-white/5 hover:border-white/10 transition-all flex items-center justify-between group">
                <div>
                    <h4 class="font-bold text-slate-200 group-hover:text-primary transition-colors flex items-center gap-2">
                        @if (isSysAdminRole)
                        {
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_8px_#ef4444]"></span>
                        }
                        else if (isAdminRole)
                        {
                            <span class="w-2.5 h-2.5 rounded-full bg-amber-500 shadow-[0_0_8px_#f59e0b]"></span>
                        }
                        else
                        {
                            <span class="w-2.5 h-2.5 rounded-full bg-[#00f4fe] shadow-[0_0_8px_#00f4fe]"></span>
                        }
                        @role.DisplayName
                    </h4>
                    <p class="text-[10px] text-slate-400 font-mono mt-1">@role.Name</p>
                </div>
                
                @if (isSysAdminRole)
                {
                    <span class="text-xs font-bold px-3 py-1 bg-red-500/10 border border-red-500/20 rounded-md text-red-400">
                        Toàn quyền
                    </span>
                }
                else
                {
                    <span class="text-xs font-bold px-3 py-1 bg-white/5 border border-white/10 rounded-md text-slate-300">
                        @(Model.RolePermissions.ContainsKey(role.Id) ? Model.RolePermissions[role.Id].Count : 0) Quyền
                    </span>
                }
            </button>
        }
    </div>

    <!-- Right column: Permissions Matrix -->
    <div class="xl:col-span-2">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Quyền truy cập chức năng</h3>
        <div id="permissionMatrixContainer" class="hidden">
            <form asp-action="UpdatePermissions" method="post" class="glass-panel p-8 rounded-3xl border border-white/10 bg-slate-900/80 shadow-2xl">
                @Html.AntiForgeryToken()
                <input type="hidden" id="selectedRoleId" name="roleId" />
                
                <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-6">
                    <div>
                        <h3 class="font-headline font-bold text-2xl text-on-surface" id="selectedRoleTitle">Chọn vai trò</h3>
                        <p class="text-xs text-on-surface-variant font-body mt-1">Cấu hình các Access Control Policy cho đối tượng này.</p>
                    </div>
                    
                    <div id="sysAdminWarning" class="hidden text-xs font-semibold py-1.5 px-3 bg-red-500/20 border border-red-500/30 text-red-300 rounded-xl">
                         Master Override: System Admin mặc định sở hữu toàn quyền.
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="checkboxGrid">
                    @foreach (var perm in Model.AvailablePermissions)
                    {
                        var parts = perm.Split('.');
                        var module = parts.Length > 0 ? parts[0] : "Chung";
                        
                        <label class="flex items-start gap-4 p-4 rounded-2xl bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] transition-all cursor-pointer">
                            <input type="checkbox" name="permissions" value="@perm" class="perm-checkbox mt-1 w-5 h-5 bg-slate-900 border-white/10 rounded-md text-primary focus:ring-primary focus:ring-offset-slate-900 focus:ring-offset-2" />
                            <div>
                                <span class="text-xs font-bold text-slate-200 block">@(permissionTranslations.TryGetValue(perm, out var vnName) ? vnName : perm)</span>
                                <span class="text-[10px] text-slate-500 uppercase font-mono tracking-widest mt-0.5 block">Mã: @perm</span>
                            </div>
                        </label>
                    }
                </div>

                <!-- Submit area -->
                <div class="flex items-center justify-end pt-6 mt-8 border-t border-white/5 gap-3" id="actionButtons">
                    <button type="submit" id="saveBtn" class="py-3 px-6 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary text-xs font-bold shadow-[0_4px_20px_rgba(97,180,254,0.3)] hover:shadow-[0_4px_30px_rgba(97,180,254,0.5)] transition-all">
                        Lưu thay đổi phân quyền
                    </button>
                </div>
            </form>
        </div>
        
        <div id="emptyState" class="glass-panel p-12 text-center rounded-3xl border border-white/10 bg-slate-900/30">
            <span class="material-symbols-outlined text-4xl text-slate-600 mb-4">security</span>
            <p class="text-slate-400 text-sm font-semibold">Vui lòng chọn một vai trò bên trái để bắt đầu phân quyền.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const rolePermissionsMapping = @Html.Raw(Json.Serialize(Model.RolePermissions));
        let userIsSysAdmin = @(User.IsInRole(RoleNames.SystemAdmin).ToString().ToLower());
        let userIsAdmin = @(User.IsInRole(RoleNames.Admin).ToString().ToLower());

        function selectRole(roleId, roleName, isSysAdminRole, isAdminRole) {
            // UI selections
            document.querySelectorAll('.role-card').forEach(el => {
                el.classList.remove('border-primary', 'bg-white/5');
            });
            document.getElementById(`role-btn-${roleId}`).classList.add('border-primary', 'bg-white/5');
            
            document.getElementById('emptyState').classList.add('hidden');
            document.getElementById('permissionMatrixContainer').classList.remove('hidden');
            
            document.getElementById('selectedRoleId').value = roleId;
            document.getElementById('selectedRoleTitle').innerText = roleName;
            
            // Checkboxes
            const checkboxes = document.querySelectorAll('.perm-checkbox');
            const mappedPerms = rolePermissionsMapping[roleId] || [];
            
            checkboxes.forEach(cb => {
                cb.checked = isSysAdminRole || mappedPerms.includes(cb.value);
            });

            // Role Scope Guard Logic
            const sysAdminWarning = document.getElementById('sysAdminWarning');
            const actionButtons = document.getElementById('actionButtons');
            const saveBtn = document.getElementById('saveBtn');

            // 1. If role is SystemAdmin, emphasize warning
            if (isSysAdminRole) {
                sysAdminWarning.classList.remove('hidden');
            } else {
                sysAdminWarning.classList.add('hidden');
            }

            // 2. Control Save Button enablement
            if (userIsSysAdmin) {
                // System Admin can do anything
                saveBtn.disabled = false;
                saveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                checkboxes.forEach(cb => cb.disabled = false);
            } else if (userIsAdmin) {
                // Admin cannot edit SystemAdmin or Admin
                if (isSysAdminRole || isAdminRole) {
                    saveBtn.disabled = true;
                    saveBtn.classList.add('opacity-50', 'cursor-not-allowed');
                    checkboxes.forEach(cb => cb.disabled = true);
                } else {
                    saveBtn.disabled = false;
                    saveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                    checkboxes.forEach(cb => cb.disabled = false);
                }
            }
        }
    </script>
}
