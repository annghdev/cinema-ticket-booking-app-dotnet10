<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Aether Cinema</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed": "#a7a9ff",
                        "secondary": "#00f4fe",
                        "on-tertiary": "#090079",
                        "surface-bright": "#282c36",
                        "surface-tint": "#61b4fe",
                        "surface-container": "#161a21",
                        "inverse-primary": "#00639f",
                        "primary-dim": "#4fa3ed",
                        "on-error-container": "#ffa8a3",
                        "secondary-container": "#00696e",
                        "on-surface": "#ecedf6",
                        "surface-variant": "#22262f",
                        "surface-dim": "#0b0e14",
                        "surface-container-high": "#1c2028",
                        "surface-container-lowest": "#000000",
                        "error-container": "#9f0519",
                        "surface": "#0b0e14",
                        "on-secondary": "#00575b",
                        "secondary-fixed-dim": "#00e5ee",
                        "on-tertiary-fixed": "#060061",
                        "primary": "#61b4fe",
                        "surface-container-highest": "#22262f",
                        "on-tertiary-fixed-variant": "#1600c3",
                        "primary-fixed-dim": "#4fa3ed",
                        "on-primary-container": "#00243f",
                        "inverse-surface": "#f9f9ff",
                        "inverse-on-surface": "#52555c",
                        "outline-variant": "#45484f",
                        "on-surface-variant": "#a9abb3",
                        "secondary-fixed": "#00f4fe",
                        "primary-fixed": "#5eb1fc",
                        "secondary-dim": "#00e5ee",
                        "error": "#ff716c",
                        "on-tertiary-container": "#ffffff",
                        "outline": "#73757d",
                        "tertiary-container": "#4949fc",
                        "on-primary-fixed-variant": "#00385d",
                        "on-secondary-container": "#dffdff",
                        "background": "#0b0e14",
                        "on-primary-fixed": "#001222",
                        "on-background": "#ecedf6",
                        "on-secondary-fixed": "#004346",
                        "primary-container": "#52a6f0",
                        "on-error": "#490006",
                        "tertiary-fixed-dim": "#9799ff",
                        "tertiary": "#9093ff",
                        "on-primary": "#003152",
                        "error-dim": "#d7383b",
                        "surface-container-low": "#10131a",
                        "on-secondary-fixed-variant": "#006266",
                        "tertiary-dim": "#5c5eff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "display": ["Space Grotesk"],
                        "body": ["Manrope"],
                        "label": ["Manrope"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-card {
            background: rgba(34, 38, 47, 0.4);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(69, 72, 79, 0.2);
        }

        .neon-glow {
            filter: drop-shadow(0 0 8px rgba(0, 244, 254, 0.5));
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body min-h-screen flex items-center justify-center bg-gradient-to-br from-background via-surface-container-low to-background">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
