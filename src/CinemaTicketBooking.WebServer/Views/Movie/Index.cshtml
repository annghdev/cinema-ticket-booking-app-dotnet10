@using CinemaTicketBooking.Application
@using CinemaTicketBooking.Application.Features
@using CinemaTicketBooking.Domain
@model PagedResult<MovieDto>

@{
    ViewData["Title"] = "Quản lý phim";
}

<div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div class="flex items-center gap-4">
        @if ((await AuthorizationService.AuthorizeAsync(User, Permissions.MoviesManage)).Succeeded)
        {
            <button onclick="openAddMovieModal()" class="py-3 px-6 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary font-bold shadow-[0_4px_20px_rgba(97,180,254,0.3)] hover:shadow-[0_4px_30px_rgba(97,180,254,0.5)] active:scale-95 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined">add</span>
                <span>Thêm Phim</span>
            </button>
        }
    </div>
</div>

<div class="glass-panel rounded-[2rem] border border-white/5 overflow-hidden shadow-2xl">
    <div class="px-8 py-6 flex items-center justify-between border-b border-white/5 bg-white/[0.01]">
        <h4 class="font-headline font-bold text-xl text-on-surface flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-secondary shadow-[0_0_8px_#00f4fe]"></span>
            Danh sách phim
        </h4>
        <form method="get" class="flex items-center gap-4">
            <input type="text" name="searchTerm" placeholder="Tìm kiếm phim..." class="bg-surface-container-high border-none text-xs rounded-xl text-slate-300 focus:ring-1 focus:ring-primary py-2 px-4 w-60" value="@Context.Request.Query["searchTerm"]" />
            <button type="submit" class="p-2 bg-surface-container-high text-slate-400 hover:text-on-surface transition-colors rounded-xl">
                <span class="material-symbols-outlined text-sm">search</span>
            </button>
        </form>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-white/[0.02]">
                <tr>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Phim</th>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Thể loại</th>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Thời lượng</th>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Hãng phim</th>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5">Trạng thái</th>
                    <th class="px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-white/5 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="px-8 py-10 text-center text-sm text-on-surface-variant">Không tìm thấy phim nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var movie in Model.Items)
                    {
                        <tr class="hover:bg-white/[0.03] transition-colors group">
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-16 rounded-lg overflow-hidden flex-shrink-0 bg-surface-container flex items-center justify-center">
                                        @if (!string.IsNullOrEmpty(movie.ThumbnailUrl))
                                        {
                                            <img src="@movie.ThumbnailUrl" class="w-full h-full object-cover" alt="@movie.Name poster" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-2xl text-slate-500">movie</span>
                                        }
                                    </div>
                                    <div>
                                        <p class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">@movie.Name</p>
                                        <p class="text-[10px] text-on-surface-variant/60 font-medium">@movie.Director</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-6">
                                <span class="px-3 py-1 rounded-full bg-white/5 text-slate-300 text-[10px] font-bold border border-white/10">@movie.Genre</span>
                            </td>
                            <td class="px-8 py-6 text-sm font-bold text-on-surface">@movie.Duration phút</td>
                            <td class="px-8 py-6 text-sm text-on-surface-variant">@movie.Studio</td>
                            <td class="px-8 py-6">
                                <span class="px-3 py-1 rounded-full @(movie.Status.ToString() == "NowShowing" ? "bg-secondary/10 text-secondary border-secondary/20" : "bg-primary/10 text-primary border-primary/20") text-[10px] font-bold border uppercase">@movie.Status</span>
                            </td>
                            <td class="px-8 py-6 text-right">
                                @if ((await AuthorizationService.AuthorizeAsync(User, Permissions.MoviesManage)).Succeeded)
                                {
                                    <button 
                                        data-id="@movie.Id"
                                        data-name="@movie.Name"
                                        data-desc="@movie.Description"
                                        data-thumb="@movie.ThumbnailUrl"
                                        data-studio="@movie.Studio"
                                        data-director="@movie.Director"
                                        data-trailer="@movie.OfficialTrailerUrl"
                                        data-duration="@movie.Duration"
                                        data-genre="@((int)movie.Genre)"
                                        onclick="openUpdateMovieModal(this)" 
                                        class="p-2 text-slate-500 hover:text-primary transition-colors">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="px-8 py-4 bg-white/[0.02] flex items-center justify-between">
        <p class="text-[10px] text-on-surface-variant font-medium">Hiển thị <span class="text-on-surface">@Model.Items?.Count() trên @Model.TotalItems</span> mục</p>
        <div class="flex items-center gap-2">
            @if (Model.PageNumber > 1)
            {
                <a href="?pageNumber=@(Model.PageNumber - 1)&searchTerm=@Context.Request.Query["searchTerm"]" class="p-2 rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 hover:text-on-surface transition-colors flex items-center">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </a>
            }
            @if (Model.PageNumber < Math.Ceiling((double)Model.TotalItems / Model.PageSize))
            {
                <a href="?pageNumber=@(Model.PageNumber + 1)&searchTerm=@Context.Request.Query["searchTerm"]" class="p-2 rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 hover:text-on-surface transition-colors flex items-center">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </a>
            }
        </div>
    </div>
</div>

<!-- Add Movie Modal -->
<div id="addMovieModal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="glass-panel w-full max-w-lg rounded-3xl border border-white/10 p-8 shadow-2xl bg-slate-900/90 relative">
        <button onclick="document.getElementById('addMovieModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
        
        <h3 class="font-headline font-bold text-2xl text-on-surface mb-6 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-primary shadow-[0_0_10px_#61b4fe]"></span>
            Thêm phim mới
        </h3>
        
        <form id="addMovieForm" class="space-y-4 text-sm">
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Tên phim</label>
                    <input type="text" name="name" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Mô tả</label>
                    <textarea name="description" rows="3" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thời lượng (phút)</label>
                    <input type="number" name="duration" required min="1" max="600" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Hãng phim</label>
                    <input type="text" name="studio" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Đạo diễn</label>
                    <input type="text" name="director" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thể loại</label>
                    <select name="genre" class="w-full py-2.5 px-4 rounded-xl bg-slate-800 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all">
                        <option value="0">Action</option>
                        <option value="1">Comedy</option>
                        <option value="2">Drama</option>
                        <option value="3">Horror</option>
                        <option value="4">SciFi</option>
                        <option value="5">Romance</option>
                        <option value="6">Thriller</option>
                        <option value="7">Animation</option>
                        <option value="8">Documentary</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Trạng thái</label>
                    <select name="status" class="w-full py-2.5 px-4 rounded-xl bg-slate-800 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all">
                        <option value="0">Upcoming</option>
                        <option value="1">NowShowing</option>
                        <option value="2">NoShow</option>
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thumbnail URL</label>
                    <input type="url" name="thumbnailUrl" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" placeholder="https://..." />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Official Trailer URL (Optional)</label>
                    <input type="url" name="officialTrailerUrl" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" placeholder="https://..." />
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-white/5 mt-4">
                <button type="button" onclick="document.getElementById('addMovieModal').classList.add('hidden')" class="py-2.5 px-5 rounded-xl bg-white/5 text-slate-300 hover:bg-white/10 text-xs font-bold transition-all">
                    Đóng
                </button>
                <button type="submit" class="py-2.5 px-6 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary text-xs font-bold shadow-[0_4px_15px_rgba(97,180,254,0.3)] hover:shadow-[0_4px_25px_rgba(97,180,254,0.5)] transition-all">
                    Thêm phim
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Update Movie Modal -->
<div id="updateMovieModal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="glass-panel w-full max-w-lg rounded-3xl border border-white/10 p-8 shadow-2xl bg-slate-900/90 relative">
        <button onclick="document.getElementById('updateMovieModal').classList.add('hidden')" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
        
        <h3 class="font-headline font-bold text-2xl text-on-surface mb-6 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-secondary shadow-[0_0_10px_#00f4fe]"></span>
            Cập nhật thông tin phim
        </h3>
        
        <form id="updateMovieForm" class="space-y-4 text-sm">
            <input type="hidden" name="id" id="updMovieId" />
            
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Tên phim</label>
                    <input type="text" id="updName" name="name" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Mô tả</label>
                    <textarea id="updDescription" name="description" rows="3" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thời lượng (phút)</label>
                    <input type="number" id="updDuration" name="duration" required min="1" max="600" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Hãng phim</label>
                    <input type="text" id="updStudio" name="studio" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Đạo diễn</label>
                    <input type="text" id="updDirector" name="director" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thể loại</label>
                    <select id="updGenre" name="genre" class="w-full py-2.5 px-4 rounded-xl bg-slate-800 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all">
                        <option value="0">Action</option>
                        <option value="1">Comedy</option>
                        <option value="2">Drama</option>
                        <option value="3">Horror</option>
                        <option value="4">SciFi</option>
                        <option value="5">Romance</option>
                        <option value="6">Thriller</option>
                        <option value="7">Animation</option>
                        <option value="8">Documentary</option>
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Thumbnail URL</label>
                    <input type="url" id="updThumbnailUrl" name="thumbnailUrl" required class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-400 mb-1">Official Trailer URL (Optional)</label>
                    <input type="url" id="updOfficialTrailerUrl" name="officialTrailerUrl" class="w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-slate-200 focus:border-primary/50 focus:ring-primary focus:outline-none transition-all" />
                </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-white/5 mt-4">
                <button type="button" onclick="deleteMovie()" class="py-2.5 px-4 rounded-xl bg-red-500/10 text-red-400 hover:bg-red-500/20 text-xs font-bold transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">delete</span>
                    Xóa phim
                </button>
                <div class="flex items-center gap-3">
                    <button type="button" onclick="document.getElementById('updateMovieModal').classList.add('hidden')" class="py-2.5 px-5 rounded-xl bg-white/5 text-slate-300 hover:bg-white/10 text-xs font-bold transition-all">
                        Đóng
                    </button>
                    <button type="submit" class="py-2.5 px-6 rounded-xl bg-gradient-to-r from-secondary to-secondary text-on-secondary text-xs font-bold shadow-[0_4px_15px_rgba(0,244,254,0.3)] hover:shadow-[0_4px_25px_rgba(0,244,254,0.5)] transition-all">
                        Lưu thay đổi
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddMovieModal() {
            document.getElementById('addMovieForm').reset();
            document.getElementById('addMovieModal').classList.remove('hidden');
        }

        function openUpdateMovieModal(btn) {
            document.getElementById('updateMovieForm').reset();
            
            document.getElementById('updMovieId').value = btn.getAttribute('data-id');
            document.getElementById('updName').value = btn.getAttribute('data-name');
            document.getElementById('updDescription').value = btn.getAttribute('data-desc');
            document.getElementById('updDuration').value = btn.getAttribute('data-duration');
            document.getElementById('updStudio').value = btn.getAttribute('data-studio');
            document.getElementById('updDirector').value = btn.getAttribute('data-director');
            document.getElementById('updThumbnailUrl').value = btn.getAttribute('data-thumb');
            document.getElementById('updOfficialTrailerUrl').value = btn.getAttribute('data-trailer') || '';
            document.getElementById('updGenre').value = btn.getAttribute('data-genre');

            document.getElementById('updateMovieModal').classList.remove('hidden');
        }

        async function deleteMovie() {
            const id = document.getElementById('updMovieId').value;
            const name = document.getElementById('updName').value;
            
            if (!confirm(`Bạn có chắc chắn muốn xóa phim "${name}" không?`)) return;

            if (window.showLoading) window.showLoading();
            try {
                const response = await fetch('/Movie/Delete?id=' + id, {
                    method: 'POST'
                });
                const result = await response.json();

                if (result.success) {
                    window.showToast(result.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    window.showToast(result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                window.showToast('Có lỗi xảy ra khi xóa phim.', 'error');
            } finally {
                if (window.hideLoading) window.hideLoading();
            }
        }

        document.getElementById('addMovieForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const payload = Object.fromEntries(formData.entries());
            
            payload.duration = parseInt(payload.duration);
            payload.genre = parseInt(payload.genre);
            payload.status = parseInt(payload.status);

            if (window.showLoading) window.showLoading();
            try {
                const response = await fetch('/Movie/Create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();

                if (result.success) {
                    window.showToast(result.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    window.showToast(result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                window.showToast('Có lỗi xảy ra khi xử lý yêu cầu.', 'error');
            } finally {
                if (window.hideLoading) window.hideLoading();
            }
        });

        document.getElementById('updateMovieForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const payload = Object.fromEntries(formData.entries());
            
            payload.duration = parseInt(payload.duration);
            payload.genre = parseInt(payload.genre);

            if (window.showLoading) window.showLoading();
            try {
                const response = await fetch('/Movie/Update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();

                if (result.success) {
                    window.showToast(result.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    window.showToast(result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                window.showToast('Có lỗi xảy ra khi xử lý yêu cầu.', 'error');
            } finally {
                if (window.hideLoading) window.hideLoading();
            }
        });
    </script>
}
