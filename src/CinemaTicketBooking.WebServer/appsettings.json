{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "cinemadb": "",
    "redis": ""
  },
  "TicketLocking": {
    "LockHoldSeconds": 300,
    "PaymentHoldSeconds": 900,
    "RecoveryBatchSize": 200
  },
  "Jwt": {
    "Issuer": "CinemaTicketBooking",
    "Audience": "CinemaTicketBooking",
    "SigningKey": "",
    "AccessTokenMinutes": 15
  },
  "RefreshToken": {
    "DaysValid": 14,
    "CookieName": "rt",
    "CookieSecure": false,
    "CookieSameSite": "Strict"
  },
  "App": {
    "PublicBaseUrl": "https://localhost:5001"
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Facebook": {
      "AppId": "",
      "AppSecret": ""
    }
  },
  "TestAuth": {
    "ExposeRefreshTokenInJson": false
  }
}
